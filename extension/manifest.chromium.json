{
  "manifest_version": 3,
  "name": "Tab Archive",
  "version": "1.0.5",
  "description": "Arc-style tab archiving with SQLite backend and sub-100ms full-text search",
  "minimum_chrome_version": "105",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tab Archive",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
