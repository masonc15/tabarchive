{
  "name": "tabarchive-extension",
  "version": "1.0.3",
  "description": "Arc-style tab archiving extension with SQLite backend",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "build:chromium": "TARGET=chromium webpack --mode production",
    "build:test": "TABARCHIVE_TEST=1 TARGET=chromium webpack --mode development",
    "watch": "webpack --mode development --watch",
    "dev": "webpack --mode development",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^1.8.8",
    "@playwright/test": "^1.42.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "jsdom": "^24.0.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "webextension-polyfill": "^0.12.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
